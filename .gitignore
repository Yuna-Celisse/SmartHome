# === MSPM0 SDK submodule ===
mspm0-sdk/docs/

# === Keil MDK / uVision ===
# Project file — MUST be tracked (contains project structure, file list, build config)
# *.uvprojx is tracked explicitly; backups only are ignored
*.uvguix.*
*.uvgui.*
*.scvd
*.uv2
*.dep
JLinkLog.txt
JLinkSettings.ini
*.uvprojx.bak
*.uvoptx.bak

# Keil build outputs
keil/Objects/
keil/Listings/
keil/*.map
keil/*.build_log.htm
keil/*.lnp
keil/*.elf
keil/*.axf
keil/*.hex
keil/*.bin
keil/*.htm
keil/*.dep
keil/*.crf
keil/*.d
keil/*.o

# Keil build viewer logs
keil/keil-build-viewer.log
keil/keil-build-viewer-record.txt

# === TI Clang / CCS ===
*.out
*.map
*.hex
*.bin
*.elf
*.a
*.lib
*.d
*.o
*.obj
*.pp

# === Compiler / linker intermediate ===
*.d
*.o
*.obj
*.lst
*.asm
*.i
*.ii

# === General build artifacts ===
build/
out/
Debug/
Release/
*.stackdump
*.core

# === IDE & Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
.DS_Store
Thumbs.db
*.orig
*.patch

# === OS files (Windows) ===
Desktop.ini
$RECYCLE.BIN/

# === Package managers (if any added later) ===
node_modules/
package-lock.json
yarn.lock
